# Copy this file to .env and fill in your values

# --- AUTH OPTION 1: Private key (MetaMask / hardware wallet) ---
POLYMARKET_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# --- AUTH OPTION 2: Google / social login accounts ---
# Get these from polymarket.com -> Settings -> API Keys
POLYMARKET_API_KEY=YOUR_API_KEY_HERE
POLYMARKET_ADDRESS=YOUR_WALLET_ADDRESS_HERE

# Optional — only if Polymarket shows you these (some account types don't):
# POLYMARKET_API_SECRET=YOUR_API_SECRET_HERE
# POLYMARKET_API_PASSPHRASE=YOUR_API_PASSPHRASE_HERE

# Telegram bot (for phone control)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE
